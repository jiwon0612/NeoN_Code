<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <engine:TextField label="State Name" name="StateNameField" binding-path="stateName" />
    <engine:DropdownField label="Class Name" name="ClassDropdownField" binding-path="className" />
    <engine:TextField label="Animation Name" name="ParamNameField" binding-path="animParamName" />
    <engine:TextField label="ClassName" name="ClassNameField" binding-path="className" readonly="true" />
</engine:UXML>
